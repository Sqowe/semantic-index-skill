{
  "schema_version": "1.0",
  "embedding": {
    "provider": "openrouter",
    "api_key": null,
    "model": "BAAI/bge-m3",
    "dimensions": 1024,
    "batch_size": 50,
    "query_prefix": "",
    "document_prefix": "",
    "max_retries": 3,
    "retry_delay_seconds": 1.0,
    "device": null,
    "trust_remote_code": false
  },
  "chunking": {
    "max_tokens": 512,
    "overlap_tokens": 50,
    "min_tokens": 20
  },
  "indexing": {
    "file_extensions": [
      ".py", ".js", ".ts", ".tsx", ".jsx",
      ".go", ".rs", ".java", ".c", ".cpp", ".h", ".hpp",
      ".rb", ".php",
      ".md", ".mdx", ".txt", ".rst",
      ".dita", ".ditamap",
      ".pdf", ".docx", ".pptx"
    ],
    "exclude_patterns": [
      "node_modules/", "venv/", ".venv/", "__pycache__/",
      "dist/", "build/", ".git/", ".index/",
      "*.min.js", "*.min.css", "*.map",
      "package-lock.json", "yarn.lock", "poetry.lock",
      "*.pyc", "*.pyo", "*.so", "*.dylib"
    ],
    "max_file_size_kb": 500,
    "max_office_file_size_kb": 50000,
    "respect_gitignore": true
  },
  "search": {
    "default_top_k": 10,
    "default_threshold": 0.3,
    "mode": "hybrid",
    "hybrid_alpha": 0.7,
    "rerank_enabled": false,
    "rerank_model": "BAAI/bge-reranker-v2-m3",
    "rerank_top_n": 10
  }
}
